        "partitions": [
          {
            "name": "FACT_CLAIMS",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " \t\t\t\tSELECT [dbo].[FACT_CLAIMS].*   FROM [dbo].[FACT_CLAIMS] ",
              "dataSource": "SqlServer DESKTOP-EEQM3AQ DWH_Healthcare"
            }
          }
        ],
        "measures": [
          {
            "name": "Distinct Count of BeneID",
            "expression": "DISTINCTCOUNT([BeneID])"
          },
          {
            "name": "Total Claims",
            "expression": "COUNT([ClaimID])"
          },
          {
            "name": "Total Reimbursed",
            "expression": "SUM([InscClaimAmtReimbursed])"
          },
          {
            "name": "Total Deductible",
            "expression": "SUM([DeductibleAmtPaid])"
          },
          {
            "name": "Average Claim Cost",
            "expression": "AVERAGE([InscClaimAmtReimbursed])"
          },
          {
            "name": "Fraud Providers",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([Provider]),",
              "    DIM_FRAUD[PotentialFraud]=\"Yes\"",
              ")"
            ]
          },
          {
            "name": "Non Fraud Providers",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([Provider]),",
              "    DIM_FRAUD[PotentialFraud]=\"No\"",
              ")"
            ]
          },
          {
            "name": "Non Fraud Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_FRAUD[PotentialFraud]=\"No\"",
              ")"
            ]
          },
          {
            "name": "Fraud Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_FRAUD[PotentialFraud]=\"Yes\"",
              ")"
            ]
          },
          {
            "name": "Fraud Claims",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNT([ClaimID]),",
              "    DIM_FRAUD[PotentialFraud]=\"Yes\"",
              ")"
            ]
          },
          {
            "name": "Non Fraud Claims",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNT([ClaimID]),",
              "    DIM_FRAUD[PotentialFraud]=\"No\"",
              ")"
            ]
          },
          {
            "name": "Fraud Reimbursed",
            "expression": [
              "",
              "CALCULATE(",
              "    SUM([InscClaimAmtReimbursed]),",
              "    DIM_FRAUD[PotentialFraud]=\"Yes\"",
              ")"
            ]
          },
          {
            "name": "Fraud Rate",
            "expression": [
              "",
              "DIVIDE(",
              "[Fraud Claims],",
              "[Total Claims]",
              ")"
            ]
          },
          {
            "name": "Inpatient Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_FRAUD[Claim_Type]=\"IP\"",
              ")"
            ]
          },
          {
            "name": "Outpatient Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_FRAUD[Claim_Type]=\"oP\"",
              ")"
            ]
          },
          {
            "name": "Inpatient Claims",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNT([ClaimID]),",
              "    DIM_FRAUD[Claim_Type]=\"IP\"",
              ")"
            ]
          },
          {
            "name": "Outpatient Claims",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNT([ClaimID]),",
              "    DIM_FRAUD[Claim_Type]=\"oP\"",
              ")"
            ]
          },
          {
            "name": "Average Part A Months",
            "expression": "AVERAGE([NoOfMonths_PartACov])"
          },
          {
            "name": "Average Part B Months",
            "expression": "AVERAGE([NoOfMonths_PartBCov])"
          },
          {
            "name": "Avg IP Part A Months",
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGE([NoOfMonths_PartACov]),",
              "    DIM_FRAUD[Claim_Type]=\"IP\"",
              ")"
            ]
          },
          {
            "name": "Avg OP Part A Months",
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGE([NoOfMonths_PartACov]),",
              "    DIM_FRAUD[Claim_Type]=\"oP\"",
              ")"
            ]
          },
          {
            "name": "Avg IP Part B Months",
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGE([NoOfMonths_PartBCov]),",
              "    DIM_FRAUD[Claim_Type]=\"IP\"",
              ")"
            ]
          },
          {
            "name": "Avg OP Part B Months",
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGE([NoOfMonths_PartBCov]),",
              "    DIM_FRAUD[Claim_Type]=\"oP\"",
              ")"
            ]
          },
          {
            "name": "Inpatient cost",
            "expression": [
              "",
              "CALCULATE(",
              "SUM([InscClaimAmtReimbursed]),",
              "DIM_FRAUD[Claim_Type]=\"IP\"",
              ")"
            ]
          },
          {
            "name": "Outpatient cost",
            "expression": [
              "",
              "CALCULATE(",
              "SUM([InscClaimAmtReimbursed]),",
              "DIM_FRAUD[Claim_Type]=\"oP\"",
              ")"
            ]
          },
          {
            "name": "Average Inpatient Cost",
            "expression": [
              "",
              "DIVIDE(",
              "    [Inpatient cost],",
              "    [Inpatient Claims]",
              ")"
            ]
          },
          {
            "name": "Inpatient Deductible",
            "expression": [
              "",
              "",
              "CALCULATE(",
              "",
              "    SUM([DeductibleAmtPaid]), ",
              "",
              "    DIM_FRAUD[Claim_Type]=\"IP\"",
              "",
              ")"
            ]
          },
          {
            "name": "Total Outpatient Deductible",
            "expression": [
              "",
              "",
              "CALCULATE(",
              "",
              "    SUM([DeductibleAmtPaid]), ",
              "",
              "    DIM_FRAUD[Claim_Type]=\"oP\"",
              "",
              ")"
            ]
          },
          {
            "name": "Diabetes Patients",
            "expression": [
              "",
              "",
              "CALCULATE(",
              "",
              "    DISTINCTCOUNT([BeneID]),",
              "",
              "    DIM_PATIENT[ChronicCond_Diabetes]=\"YES\"",
              "",
              ")"
            ]
          },
          {
            "name": "Heart Failure Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_Heartfailure]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Kidney Disease Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_KidneyDisease]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Renal Disease Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[RenalDiseaseIndicator]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Stroke Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_stroke]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Rheumatoid Arthritis Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_RheumatoidArthritis]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Osteoporosis Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_Osteoporasis]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Ischemic Heart Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_IschemicHeart]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Alzheimer Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_Alzheimer]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "COPD Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_ObstrPulmonary]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Depression Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_Depression]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Cancer Patients",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT([BeneID]),",
              "    DIM_PATIENT[ChronicCond_Cancer]=\"YES\"",
              ")"
            ]
          },
          {
            "name": "Average Outpatient Cost",
            "expression": [
              "",
              "DIVIDE(",
              "    [Outpatient cost],",
              "    [Outpatient Claims]",
              ")"
            ]
          }
        ],
