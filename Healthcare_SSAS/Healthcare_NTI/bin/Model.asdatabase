          },
          {
            "type": "calculated",
            "name": "Claim Type Name",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "SWITCH(",
              "    UPPER([Claim_Type]),",
              "    \"IP\", \"Inpatient\",",
              "    \"OP\", \"Outpatient\",",
              "    [Claim_Type]",
              ")"
