                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT [ProcedureCode] FROM (
    SELECT [ClmProcedureCode_1] AS [ProcedureCode] FROM dbo.DIM_Claim_Procedures WHERE [ClmProcedureCode_1] IS NOT NULL AND [ClmProcedureCode_1] &lt;&gt; ''
    UNION
    SELECT [ClmProcedureCode_2] FROM dbo.DIM_Claim_Procedures WHERE [ClmProcedureCode_2] IS NOT NULL AND [ClmProcedureCode_2] &lt;&gt; ''
    UNION
    SELECT [ClmProcedureCode_3] FROM dbo.DIM_Claim_Procedures WHERE [ClmProcedureCode_3] IS NOT NULL AND [ClmProcedureCode_3] &lt;&gt; ''
    UNION
    SELECT [ClmProcedureCode_4] FROM dbo.DIM_Claim_Procedures WHERE [ClmProcedureCode_4] IS NOT NULL AND [ClmProcedureCode_4] &lt;&gt; ''
    UNION
    SELECT [ClmProcedureCode_5] FROM dbo.DIM_Claim_Procedures WHERE [ClmProcedureCode_5] IS NOT NULL AND [ClmProcedureCode_5] &lt;&gt; ''
    UNION
    SELECT [ClmProcedureCode_6] FROM dbo.DIM_Claim_Procedures WHERE [ClmProcedureCode_6] IS NOT NULL AND [ClmProcedureCode_6] &lt;&gt; ''
) AS AllProcedures;</property>
