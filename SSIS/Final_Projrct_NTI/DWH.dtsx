                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT [PhysicianID] FROM (
    SELECT [AttendingPhysician] AS [PhysicianID] FROM dbo.DIM_PHYSICIAN WHERE [AttendingPhysician] IS NOT NULL AND [AttendingPhysician] &lt;&gt; ''
    UNION
    SELECT [OperatingPhysician] FROM dbo.DIM_PHYSICIAN WHERE [OperatingPhysician] IS NOT NULL AND [OperatingPhysician] &lt;&gt; ''
