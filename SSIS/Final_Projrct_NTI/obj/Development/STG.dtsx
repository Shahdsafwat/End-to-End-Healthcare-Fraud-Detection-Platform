                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset">[dbo].[ODS_Healthcare_All_Claims]</property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 

    -- 1. Clean Attending Physician Code
    CASE 
        WHEN [AttendingPhysician] IS NULL 
             OR [AttendingPhysician] = 'NA' 
             OR TRIM([AttendingPhysician]) = '' 
        THEN NULL
        ELSE TRIM([AttendingPhysician])
    END AS [Clean_AttendingPhysician],


    -- 2. Clean Operating Physician Code
    CASE 
        WHEN [OperatingPhysician] IS NULL 
             OR [OperatingPhysician] = 'NA' 
             OR TRIM([OperatingPhysician]) = '' 
        THEN NULL
        ELSE TRIM([OperatingPhysician])
    END AS [Clean_OperatingPhysician],


    -- 3. Clean Other Physician Code
    CASE 
        WHEN [OtherPhysician] IS NULL 
             OR [OtherPhysician] = 'NA' 
             OR TRIM([OtherPhysician]) = '' 
        THEN NULL
        ELSE TRIM([OtherPhysician])
    END AS [Clean_OtherPhysician]


FROM [ODS_Project].[dbo].[ODS_Healthcare_All_Claims];</property>
