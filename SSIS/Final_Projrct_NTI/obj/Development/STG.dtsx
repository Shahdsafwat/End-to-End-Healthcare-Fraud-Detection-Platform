                <component
                  refId="Package\Sequence Container\DIM_CHRONIC_CONDITIONS\OLE DB Source"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    RenalDiseaseIndicator,
    CASE 
        WHEN ChronicCond_Alzheimer = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_Alzheimer = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_Alzheimer,
    CASE 
        WHEN ChronicCond_Heartfailure = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_Heartfailure = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_Heartfailure,
    CASE 
        WHEN ChronicCond_KidneyDisease = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_KidneyDisease = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_KidneyDisease,
    CASE 
        WHEN ChronicCond_Cancer = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_Cancer = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_Cancer,
    CASE 
        WHEN ChronicCond_ObstrPulmonary = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_ObstrPulmonary = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_ObstrPulmonary,
    CASE 
        WHEN ChronicCond_Depression = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_Depression = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_Depression,
    CASE 
        WHEN ChronicCond_Diabetes = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_Diabetes = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_Diabetes,
    CASE 
        WHEN ChronicCond_IschemicHeart = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_IschemicHeart = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_IschemicHeart,
    CASE 
        WHEN ChronicCond_Osteoporasis = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_Osteoporasis = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_Osteoporasis,
    CASE 
        WHEN ChronicCond_rheumatoidarthritis = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_rheumatoidarthritis = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_rheumatoidarthritis,
    CASE 
        WHEN ChronicCond_stroke = 1 THEN CAST('YES' AS NVARCHAR(3))
        WHEN ChronicCond_stroke = 2 THEN CAST('NO' AS NVARCHAR(3))
        ELSE NULL
    END AS ChronicCond_stroke
FROM [ODS_Project].[dbo].[ODS_Healthcare_All_Claims];</property>
